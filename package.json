    "test:rendering": "node src/rendering/rendering.test.js",
    "example:rendering": "node src/rendering/rendering.examples.js",
    "test:core:ai": "node src/core/ai/intentService.test.js",
    "test:core:experience": "node src/core/experience/gameStateManager.test.js",
    "example:core": "node src/core/corePipeline.examples.js",
    "test:all": "npm run test:intent && npm run test:simulation && npm run test:rendering && npm run test:core:ai && npm run test:core:experience"
